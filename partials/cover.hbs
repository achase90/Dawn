<section class="os-hero">
    <div class="os-hero-inner">
        {{#if @custom.hero_title}}
            <h1 class="os-hero-title">{{@custom.hero_title}}</h1>
        {{else}}
            <h1 class="os-hero-title">{{@site.title}}</h1>
        {{/if}}

        {{#if @site.description}}
            <p class="os-hero-tagline">{{@site.description}}</p>
        {{/if}}

        {{#if @custom.hero_credibility}}
            <div class="os-hero-credibility">{{@custom.hero_credibility}}</div>
        {{/if}}
    </div>
</section>
