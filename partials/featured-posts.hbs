{{#get "posts" filter="featured:true" limit="2" include="tags" as |featured|}}
{{#if featured}}
    <div class="os-featured-wrapper">
        <div class="os-section-header">
            <h2>{{@custom.featured_title}}</h2>
        </div>
        <div class="os-cards-grid">
            {{#foreach featured}}
            <a href="{{url}}" class="os-card">
                <div class="os-card-body">
                    {{#primary_tag}}
                        <span class="os-badge os-badge-{{slug}}">{{name}}</span>
                    {{/primary_tag}}
                    <h3 class="os-card-title">{{title}}</h3>
                    <p class="os-card-excerpt">{{excerpt words="25"}}</p>
                    <div class="os-card-meta">{{reading_time}} · {{date published_at format="MMM D, YYYY"}}</div>
                </div>
                <div class="os-card-footer">
                    <span class="os-card-cta">Read article <span class="os-arrow">→</span></span>
                </div>
            </a>
            {{/foreach}}
        </div>
    </div>
{{/if}}
{{/get}}
